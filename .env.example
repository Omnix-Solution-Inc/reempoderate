# =============================================
# ReEmpoderate Platform — Environment Variables
# Copy this file to .env.local for development
# =============================================

# ── Base44 Backend ───────────────────────────
NEXT_PUBLIC_BASE44_APP_ID=6a066d4f6fb4352d1a5946c3
NEXT_PUBLIC_BASE44_API_URL=https://witmakers-1a5946c3.base44.app/functions

# ── NextAuth ─────────────────────────────────
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-here-generate-with-openssl-rand-base64-32

# ── Google OAuth ─────────────────────────────
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# ── Microsoft OAuth ──────────────────────────
AZURE_AD_CLIENT_ID=your-azure-client-id
AZURE_AD_CLIENT_SECRET=your-azure-client-secret
AZURE_AD_TENANT_ID=your-azure-tenant-id

# ── Gemini AI (coaching engine) ───────────────
GEMINI_API_KEY=your-gemini-api-key

# ── Active Environment ────────────────────────
# Options: reempoderate | bella-wildflower
NEXT_PUBLIC_ENVIRONMENT=reempoderate

# ── Domain Config ─────────────────────────────
NEXT_PUBLIC_BASE_DOMAIN=reempoderate.com
# Vercel sets this automatically in production:
# NEXT_PUBLIC_VERCEL_URL=your-deployment.vercel.app
